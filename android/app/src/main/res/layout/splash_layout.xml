<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash-Layout für die SplashActivity.
    Hintergrund matcht ic_launcher_background (#FFFFFF), damit der Übergang
    vom System-Splash zur Activity nicht "blinkt".
    Status- und Navigationsleiste werden in SplashActivity.onCreate ausgeblendet.

    RelativeLayout (statt LinearLayout) sorgt dafür, dass das Icon exakt im
    Screen-Mittelpunkt sitzt — der Spinner wird relativ darunter positioniert
    und verschiebt das Icon nicht aus der Mitte.
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ic_launcher_background">

    <ImageView
        android:id="@+id/splash_icon"
        android:layout_width="144dp"
        android:layout_height="144dp"
        android:layout_centerInParent="true"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="@null" />

    <ProgressBar
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/splash_icon"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:indeterminate="true" />

</RelativeLayout>
